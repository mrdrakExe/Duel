--â”€â”€ RenderStepped: speed hack + FPS / Ping update â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

local frameCount = 0
local lastFPSTick = tick()

RunService.RenderStepped: Connect(function ()
    --Character safety check
    if not Character or not RootPart then return end
    local hum = Character: FindFirstChildOfClass("Humanoid")
if not hum then return end

--Speed override: project movement direction onto target speed
    local moveDir = hum.MoveDirection
if moveDir.Magnitude > 0.1 then
        local targetSpeed = State.CarryMode
and(tonumber(CarrySpeedBox.Text)  or Config.CarrySpeed)
or(tonumber(NormalSpeedBox.Text) or Config.NormalSpeed)

RootPart.Velocity = Vector3.new(
  moveDir.X * targetSpeed,
  RootPart.Velocity.Y, --preserve vertical(gravity / jump)
            moveDir.Z * targetSpeed
)
end

--Billboard speed readout
    local xzVel = Vector3.new(RootPart.Velocity.X, 0, RootPart.Velocity.Z).Magnitude
SpeedBillboardLabel.Text = string.format("Speed: %.1f", xzVel)
StatusLabel.Text = string.format("Speed: %.1f", xzVel)

--FPS counter(updated once per second)
frameCount = frameCount + 1
    local now = tick()
if now - lastFPSTick >= 1 then
        local fps = math.round(frameCount / (now - lastFPSTick))
        local pingMs = math.round(LocalPlayer: GetNetworkPing() * 1000)
FPSLabel.Text = string.format("FPS: %d;|;Ping: %dms", fps, pingMs)
frameCount = 0
lastFPSTick = now
end
end)


