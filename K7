indicatorBg.Parent = row
addCorner(indicatorBg, 12)

    local dot = Instance.new("Frame")
dot.Size = UDim2.new(0, 20, 0, 20)
dot.Position = UDim2.new(0, 2, 0.5, -10)
dot.BackgroundColor3 = COLOR_WHITE
dot.BorderSizePixel = 0
dot.Parent = indicatorBg
addCorner(dot, 10)

    local enabled = false
    local function toggle()
enabled = not enabled
TweenService: Create(dot, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
  Position = enabled
                and UDim2.new(1, -22, 0.5, -10)
                or  UDim2.new(0, 2, 0.5, -10)
}): Play()
indicatorBg.BackgroundColor3 = enabled and COLOR_ACCENT or COLOR_TOGGLE_OFF
if onToggle then onToggle(enabled) end
end

row.MouseButton1Click: Connect(toggle)
if keyBtn.Visible then keyBtn.MouseButton1Click: Connect(toggle) end

return {
  container = row, keyBtn = keyBtn, dot = dot,
  indicatorBg = indicatorBg, toggle = toggle, enabled = function () return enabled end
}
end


